#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    timeCodesPerSecond = 24
    upAxis = "Y"
)

def Xform "World"
{
    # ── Articulation: a tree of rigid bodies connected by joints ──────────────
    # ArticulationRootAPI marks the root of an articulation hierarchy.
    # Articulations use reduced-coordinate (Featherstone) solvers.
    def Xform "RobotArm" (
        prepend apiSchemas = ["PhysicsArticulationRootAPI"]
    )
    {
        # Base link: fixed to the world
        def Cube "Base" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsCollisionAPI"]
        )
        {
            double size = 80.0
            bool physics:kinematicEnabled = true    # Base is kinematic (anchored)
        }

        # Upper arm: connected to base by a revolute joint
        def Cube "UpperArm" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsCollisionAPI"]
        )
        {
            double size = 30.0
            float3 xformOp:scale = (1, 3, 1)
            double3 xformOp:translate = (0, 120, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def PhysicsRevoluteJoint "ShoulderJoint" (
            prepend apiSchemas = ["PhysicsLimitAPI:rotZ", "PhysicsDriveAPI:rotZ"]
        )
        {
            rel physics:body0 = </World/RobotArm/Base>
            rel physics:body1 = </World/RobotArm/UpperArm>
            uniform token physics:axis = "Z"
            float physics:rotZ:low = -120.0
            float physics:rotZ:high = 120.0
            float physics:rotZ:stiffness = 5000.0
            float physics:rotZ:damping = 500.0
            float physics:rotZ:targetPosition = 45.0
            token physics:rotZ:type = "force"
        }
    }
}
